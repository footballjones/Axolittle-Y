<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- The app does not use data for tracking users across apps/websites. -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- No advertising/analytics tracking domains. -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!--
        Data the app collects and links to the user's identity.
        Supabase authentication stores a user account (email + user ID) and
        syncs game progress to the developer's Supabase backend.
        If you remove Supabase auth before submission, remove these entries.
    -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array>
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeEmailAddress</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeUserID</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeOtherDataTypes</string>
            <!-- Game state (axolotl stats, inventory, progress) synced to backend. -->
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>
    </array>

    <!--
        Required-reason APIs accessed by the native layer.
        The WKWebView wrapper itself does not call UserDefaults, file-timestamp,
        disk-space, boot-time, or active-keyboard APIs directly.
        If you add any such calls in future native code, declare them here.
    -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array/>
</dict>
</plist>
