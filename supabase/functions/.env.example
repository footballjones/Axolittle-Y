# Edge function secrets — set via `supabase secrets set <KEY>=<VALUE>`
# (or in Supabase Dashboard → Edge Functions → Settings → Secrets).
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected — do not set them.

# Origin of the deployed SPA — used as the redirect target on recovery links.
APP_URL=https://axolittle.app

# Resend account (https://resend.com). Get an API key + verify a sending domain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RECOVERY_FROM_EMAIL=noreply@axolittle.app
